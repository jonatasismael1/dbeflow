# ===========================================================================
# DBE FLOW — Modelo de variáveis de ambiente
# Copie para .env e preencha. Frontend só lê variáveis VITE_.
# ===========================================================================

# --- App ---
VITE_APP_NAME=DBE Flow
VITE_APP_URL=http://127.0.0.1:5173

# --- Supabase ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ACCESS_TOKEN=

# --- WhatsApp (Evolution API) ---
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=dbe-flow
EVOLUTION_WEBHOOK_SECRET=

# --- Meta / Instagram ---
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_GRAPH_API_VERSION=v25.0
VITE_META_APP_ID=

# --- IA (OpenRouter) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_AI_MODEL=meta-llama/llama-3.3-70b-instruct:free

# --- Google ---
GOOGLE_CLIENT_EMAIL=
GOOGLE_SHEETS_ID=
GOOGLE_DRIVE_FOLDER_ID=
